      <column aggregation='Sum' datatype='integer' name='[Age]' role='dimension' type='ordinal' />
      <column aggregation='Avg' datatype='real' name='[BMI]' role='measure' type='quantitative' />
      <column datatype='string' name='[Blood Pressure Systolic]' role='dimension' type='nominal' />
      <column caption='BMI Type' datatype='string' name='[Calculation_217650550151471104]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [BMI]&lt;18.5 THEN &apos;Underweight&apos;&#10;ELSEIF [BMI]&gt;=18.5 and [BMI]&lt;25 then &apos;Healthy Weight&apos;&#10;ELSEIF [BMI]&gt;=25 and [BMI]&lt;30 then &apos;Overweight&apos;&#10;ELSEIF [BMI]&gt;=30 then &apos;Obese&apos;&#10;END' />
      </column>
      <column caption='Diabetic / Non-Diabetic' datatype='string' name='[Calculation_217650550151737346]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Outcome] =1 THEN &quot;Diabetic&quot;&#10;ELSEIF [Outcome]=0 THEN &quot;Non-Diabetic&quot;&#10;END' />
      </column>
      <column caption='BP calculation' datatype='string' name='[Calculation_217650550151917571]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='If [Calculation_217650550151737346]=&apos;Diabetic&apos; and&#10;([Blood Pressure Systolic]= &apos;High&apos; or [Blood Pressure Systolic]=&apos;Low&apos;) then &apos;1&apos;&#10;END' />
      </column>
